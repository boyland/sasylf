{
  "name": "sasylf",
  "displayName": "SASyLF",
  "description": "Language support for SASyLF proof assistant",
  "version": "0.1.0",
  "publisher": "sasylf",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:sasylf"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sasylf",
        "aliases": [
          "SASyLF",
          "sasylf"
        ],
        "extensions": [
          ".slf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sasylf",
        "scopeName": "source.sasylf",
        "path": "./syntaxes/sasylf.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "SASyLF",
      "properties": {
        "sasylf.java.home": {
          "type": "string",
          "default": "",
          "description": "Path to Java home directory"
        },
        "sasylf.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
